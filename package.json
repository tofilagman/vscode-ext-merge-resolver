{
  "name": "merge-resolver",
  "displayName": "Merge Resolver",
  "description": "IntelliJ-style 3-way merge conflict resolver — Yours | Result | Theirs side-by-side, apply non-conflicting changes in one click.",
  "version": "1.0.2",
  "publisher": "tofilagman",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofilagman/vscode-ext-merge-resolver.git"
  },
  "bugs": {
    "url": "https://github.com/tofilagman/vscode-ext-merge-resolver/issues"
  },
  "homepage": "https://github.com/tofilagman/vscode-ext-merge-resolver#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "merge",
    "conflict",
    "3-way",
    "diff3",
    "intellij"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mergeResolver",
          "title": "Merge Resolver",
          "icon": "media/merge.svg"
        }
      ]
    },
    "views": {
      "mergeResolver": [
        {
          "id": "mergeResolver.conflicts",
          "name": "Conflicts",
          "icon": "media/merge.svg",
          "contextualTitle": "Merge Resolver"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "mergeResolver.conflicts",
        "contents": "No merge conflicts detected.\nAfter a merge, pull, or rebase that produces conflicts, the conflicted files will appear here.\n[Refresh](command:mergeResolver.refresh)"
      }
    ],
    "commands": [
      {
        "command": "mergeResolver.refresh",
        "title": "Merge Resolver: Refresh Conflicts",
        "icon": "$(refresh)"
      },
      {
        "command": "mergeResolver.resolve",
        "title": "Merge Resolver: Open 3-Way Merge",
        "icon": "$(git-merge)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mergeResolver.refresh",
          "when": "view == mergeResolver.conflicts",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "mergeResolver.resolve",
          "when": "view == mergeResolver.conflicts && viewItem == conflict",
          "group": "inline@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit",
    "package": "npm run build && vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "monaco-editor": "^0.52.0",
    "node-diff3": "^3.1.2"
  }
}
